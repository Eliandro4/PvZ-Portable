<?xml version="1.0" encoding="utf-8"?>
<!-- Matches any USB HID device that exposes a gamepad/joystick interface
     (USB device class 0x03 = HID). This lets SDL's SDLControllerManager
     claim wired/OTG controllers. -->
<resources>
    <usb-device class="3" subclass="0" protocol="0" />
</resources>
